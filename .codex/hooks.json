{
  "description": "Repo-local Codex hook bridge for DAE runtime enforcement during local development. Production installs use scripts/install-codex-dae.sh --runtime-enforcement to write the user-level bridge.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PWD/scripts/codex-init.sh\"",
            "timeout": 30,
            "statusMessage": "Preparing kdoronin/dae_codex git context"
          },
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"$PWD/plugins/engineer\" python3 \"$PWD/plugins/engineer/scripts/dae_guard.py\" session-start",
            "timeout": 30,
            "statusMessage": "Loading DAE runtime contract"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"$PWD/plugins/engineer\" python3 \"$PWD/plugins/engineer/scripts/dae_guard.py\" user-prompt-submit",
            "timeout": 30,
            "statusMessage": "Checking DAE prompt gate"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"$PWD/plugins/engineer\" python3 \"$PWD/plugins/engineer/scripts/dae_guard.py\" pre-tool-use",
            "timeout": 30,
            "statusMessage": "Checking DAE pre-tool gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"$PWD/plugins/engineer\" python3 \"$PWD/plugins/engineer/scripts/dae_guard.py\" post-tool-use",
            "timeout": 30,
            "statusMessage": "Recording DAE tool evidence"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"$PWD/plugins/engineer\" python3 \"$PWD/plugins/engineer/scripts/dae_guard.py\" permission-request",
            "timeout": 30,
            "statusMessage": "Checking DAE permission gate"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"$PWD/plugins/engineer\" python3 \"$PWD/plugins/engineer/scripts/dae_guard.py\" stop",
            "timeout": 30,
            "statusMessage": "Checking DAE completion gate"
          }
        ]
      }
    ]
  }
}
