{
  "description": "ATDD compatibility hooks for Codex CLI. Runtime policy delegates to the engineer plugin's unified DAE guard.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/scripts/check-specs-exist.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/scripts/stop-reminder.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
